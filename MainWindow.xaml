<Window x:Class="SmartHouseApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart House"
        Height="650"
        Width="1100"
        Background="#1E1E2E">

     <Grid>
          <Grid.ColumnDefinitions>
               <ColumnDefinition Width="220"/>
               <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <!-- SIDEBAR -->
          <StackPanel Background="#111827" Grid.Column="0">

               <TextBlock Text="SMART HOUSE"
                       Foreground="White"
                       FontSize="18"
                       Margin="20"
                       FontWeight="Bold"/>

               <Button Content="Dashboard" Click="Dashboard_Click" Margin="10"/>
               <Button Content="Rooms" Click="Rooms_Click" Margin="10"/>
               <Button Content="Devices" Click="Devices_Click" Margin="10"/>
               <Button Content="Logs" Click="Logs_Click" Margin="10"/>

          </StackPanel>

          <!-- CONTENT -->
          <ContentControl x:Name="MainContent" Grid.Column="1"/>
     </Grid>
</Window>