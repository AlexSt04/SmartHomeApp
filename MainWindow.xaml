<Window x:Class="SmartHouseApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart House Professional"
        Height="700"
        Width="1200"
        Background="{StaticResource PrimaryBackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Background="#111827" Grid.Column="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <StackPanel Margin="0,30,0,0">
                <TextBlock Text="SMART HOUSE"
                           Style="{StaticResource HeadingL}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,40"
                           Foreground="{StaticResource AccentPrimaryBrush}"/>

                <StackPanel Margin="10,0">
                    <Button Content="📊 Dashboard" Click="Dashboard_Click" Style="{StaticResource {x:Type Button}}" Margin="0,5" HorizontalContentAlignment="Left" Padding="20,12"/>
                    <Button Content="🏠 Rooms" Click="Rooms_Click" Style="{StaticResource {x:Type Button}}" Margin="0,5" HorizontalContentAlignment="Left" Padding="20,12"/>
                    <Button Content="⚡ Devices" Click="Devices_Click" Style="{StaticResource {x:Type Button}}" Margin="0,5" HorizontalContentAlignment="Left" Padding="20,12"/>
                    <Button Content="📋 Logs" Click="Logs_Click" Style="{StaticResource {x:Type Button}}" Margin="0,5" HorizontalContentAlignment="Left" Padding="20,12"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Width="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid Margin="25,0">
                    <TextBlock x:Name="PageTitle" Text="Dashboard" VerticalAlignment="Center" Style="{StaticResource HeadingM}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="⚙️ Settings" VerticalAlignment="Center" Cursor="Hand" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ContentControl x:Name="MainContent" Grid.Row="1" Margin="25"/>
        </Grid>
    </Grid>
</Window>