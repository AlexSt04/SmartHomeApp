<UserControl x:Class="SmartHouseApp.Views.Pages.ScenesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d">

     <UserControl.Resources>
          <BooleanToVisibilityConverter x:Key="BoolVis"/>
     </UserControl.Resources>

     <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel>

               <!-- STATUS BANNER -->
               <Border Background="#064E3B" CornerRadius="8" Padding="20,14"
                    Margin="0,0,0,20"
                    Visibility="{Binding ShowStatus, Converter={StaticResource BoolVis}}">
                    <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#6EE7B7" FontSize="14" FontWeight="SemiBold"/>
               </Border>

               <!-- PRESET SCENES HEADER -->
               <TextBlock Text="Quick Scenes" Style="{StaticResource HeadingL}" Margin="0,0,0,4"/>
               <TextBlock Text="Activează o configurație completă cu un singur click."
                       Style="{StaticResource SmallText}" Margin="0,0,0,20"/>

               <!-- 2x2 PRESET GRID -->
               <UniformGrid Columns="2" Margin="0,0,0,35">
                    <ItemsControl ItemsSource="{Binding PresetCards}">
                         <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                   <UniformGrid Columns="2"/>
                              </ItemsPanelTemplate>
                         </ItemsControl.ItemsPanel>
                         <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                   <Border Background="#1A1A2E" CornerRadius="12"
                                    Margin="8" MinHeight="195"
                                    BorderBrush="#2A2A3E" BorderThickness="1">
                                        <Border.Effect>
                                             <DropShadowEffect ShadowDepth="2" BlurRadius="12" Opacity="0.5"/>
                                        </Border.Effect>
                                        <Grid>
                                             <Grid.RowDefinitions>
                                                  <RowDefinition Height="5"/>
                                                  <RowDefinition Height="*"/>
                                             </Grid.RowDefinitions>

                                             <!-- Accent top bar -->
                                             <Border Grid.Row="0"
                                            Background="{Binding AccentBrush}"
                                            CornerRadius="12,12,0,0"/>

                                             <StackPanel Grid.Row="1" Margin="20,15,20,20">

                                                  <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                       <TextBlock Text="{Binding Icon}"
                                                       FontSize="28" VerticalAlignment="Center"
                                                       Margin="0,0,10,0"/>
                                                       <TextBlock Text="{Binding Name}"
                                                       FontSize="17" FontWeight="Bold"
                                                       Foreground="White" VerticalAlignment="Center"/>
                                                  </StackPanel>

                                                  <TextBlock Text="{Binding Description}"
                                                   Foreground="#9CA3AF" FontSize="12"
                                                   TextWrapping="Wrap" Margin="0,0,0,10"/>

                                                  <TextBlock Text="{Binding DeviceTags}"
                                                   Foreground="#4B5563" FontSize="11"
                                                   TextWrapping="Wrap" Margin="0,0,0,15"/>

                                                  <Button Command="{Binding ActivateCommand}"
                                                Background="{Binding AccentBrush}"
                                                Foreground="White"
                                                FontWeight="Bold" FontSize="13"
                                                BorderThickness="0" Cursor="Hand"
                                                Padding="0,10">
                                                       <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                 <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="8"
                                                            Padding="{TemplateBinding Padding}">
                                                                      <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                                 </Border>
                                                            </ControlTemplate>
                                                       </Button.Template>
                                                       <TextBlock Text="▶  Activate Scene"
                                                       HorizontalAlignment="Center"
                                                       Foreground="White" FontWeight="Bold"/>
                                                  </Button>
                                             </StackPanel>
                                        </Grid>
                                   </Border>
                              </DataTemplate>
                         </ItemsControl.ItemTemplate>
                    </ItemsControl>
               </UniformGrid>

               <!-- CUSTOM SCENES HEADER -->
               <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                         <ColumnDefinition Width="*"/>
                         <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                         <TextBlock Text="Custom Scenes" Style="{StaticResource HeadingL}"/>
                         <TextBlock Text="Scenele tale personalizate." Style="{StaticResource SmallText}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="＋  New Scene"
                        Command="{Binding ToggleCreateCommand}"
                        Padding="20,10" VerticalAlignment="Center"/>
               </Grid>

               <!-- CUSTOM LIST -->
               <ItemsControl ItemsSource="{Binding CustomCards}" Margin="0,0,0,15">
                    <ItemsControl.ItemTemplate>
                         <DataTemplate>
                              <Border Background="#1A1A2E" CornerRadius="10"
                                Margin="0,0,0,10" Padding="18,14"
                                BorderBrush="#2A2A3E" BorderThickness="1">
                                   <Grid>
                                        <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="48"/>
                                             <ColumnDefinition Width="*"/>
                                             <ColumnDefinition Width="Auto"/>
                                             <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Icon}"
                                           FontSize="26" VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                                             <TextBlock Text="{Binding Name}"
                                               FontSize="15" FontWeight="Bold" Foreground="White"/>
                                             <TextBlock Text="{Binding Description}"
                                               Foreground="#6B7280" FontSize="12" Margin="0,2,0,0"/>
                                             <TextBlock Text="{Binding DeviceTags}"
                                               Foreground="#4B5563" FontSize="11" Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <Button Grid.Column="2"
                                        Content="▶  Run"
                                        Command="{Binding ActivateCommand}"
                                        Padding="18,8" Margin="0,0,10,0"/>

                                        <Button Grid.Column="3" Content="🗑"
                                        Command="{Binding DeleteCommand}"
                                        Background="#7F1D1D" Foreground="White"
                                        Padding="12,8" BorderThickness="0" Cursor="Hand">
                                             <Button.Template>
                                                  <ControlTemplate TargetType="Button">
                                                       <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                                       </Border>
                                                  </ControlTemplate>
                                             </Button.Template>
                                        </Button>
                                   </Grid>
                              </Border>
                         </DataTemplate>
                    </ItemsControl.ItemTemplate>
               </ItemsControl>

               <!-- CREATE NEW SCENE PANEL -->
               <Border Background="#0D1117" CornerRadius="12"
                    BorderBrush="#10B981" BorderThickness="1"
                    Padding="25" Margin="0,0,0,20"
                    Visibility="{Binding ShowCreate, Converter={StaticResource BoolVis}}">
                    <StackPanel>

                         <TextBlock Text="Create New Scene" Style="{StaticResource HeadingM}"
                               Foreground="#10B981" Margin="0,0,0,20"/>

                         <!-- Name + Icon -->
                         <Grid Margin="0,0,0,15">
                              <Grid.ColumnDefinitions>
                                   <ColumnDefinition Width="*"/>
                                   <ColumnDefinition Width="180"/>
                              </Grid.ColumnDefinitions>
                              <StackPanel Margin="0,0,15,0">
                                   <TextBlock Text="Scene Name" Style="{StaticResource SmallText}" Margin="0,0,0,6"/>
                                   <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="Ex: Game Night, Dinner..."/>
                              </StackPanel>
                              <StackPanel Grid.Column="1">
                                   <TextBlock Text="Icon" Style="{StaticResource SmallText}" Margin="0,0,0,6"/>
                                   <ComboBox ItemsSource="{Binding IconOptions}"
                                      SelectedItem="{Binding NewIcon}"
                                      Height="38" VerticalContentAlignment="Center"
                                      Background="#1E1E2E" Foreground="#1E1E2E"/>
                              </StackPanel>
                         </Grid>

                         <!-- Actions header -->
                         <Grid Margin="0,0,0,10">
                              <Grid.ColumnDefinitions>
                                   <ColumnDefinition Width="*"/>
                                   <ColumnDefinition Width="Auto"/>
                              </Grid.ColumnDefinitions>
                              <TextBlock Text="Actions" Style="{StaticResource SmallText}" VerticalAlignment="Center"/>
                              <Button Grid.Column="1" Content="＋ Add Action"
                                Command="{Binding AddActionRowCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Padding="12,6" FontSize="12"/>
                         </Grid>

                         <!-- Action rows -->
                         <ItemsControl ItemsSource="{Binding NewActions}" Margin="0,0,0,20">
                              <ItemsControl.ItemTemplate>
                                   <DataTemplate>
                                        <Border Background="#1E1E2E" CornerRadius="8"
                                        Margin="0,0,0,8" Padding="14,10">
                                             <Grid>
                                                  <Grid.ColumnDefinitions>
                                                       <ColumnDefinition Width="*"/>
                                                       <ColumnDefinition Width="*"/>
                                                       <ColumnDefinition Width="130"/>
                                                       <ColumnDefinition Width="36"/>
                                                  </Grid.ColumnDefinitions>

                                                  <ComboBox Grid.Column="0"
                                                  ItemsSource="{Binding DeviceTypes}"
                                                  SelectedItem="{Binding DeviceType}"
                                                  Height="36" VerticalContentAlignment="Center"
                                                  Background="#2A2A3E" Foreground="White"
                                                  Margin="0,0,8,0"/>

                                                  <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding ActionTypes}"
                                                  SelectedItem="{Binding ActionType}"
                                                  Height="36" VerticalContentAlignment="Center"
                                                  Background="#2A2A3E" Foreground="White"
                                                  Margin="0,0,8,0"/>

                                                  <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                    Margin="0,0,8,0"
                                                    Visibility="{Binding ShowTemp, Converter={StaticResource BoolVis}}">
                                                       <TextBlock Text="{Binding Temperature, StringFormat='{}{0}°C'}"
                                                       Style="{StaticResource SmallText}" HorizontalAlignment="Center"/>
                                                       <Slider Minimum="16" Maximum="30"
                                                    Value="{Binding Temperature}"
                                                    IsSnapToTickEnabled="True" TickFrequency="1"/>
                                                  </StackPanel>

                                                  <Button Grid.Column="3" Content="✕"
                                                Command="{Binding RemoveCommand}"
                                                Background="Transparent" Foreground="#EF4444"
                                                BorderThickness="0" FontSize="15" Cursor="Hand"
                                                VerticalAlignment="Center" HorizontalAlignment="Center">
                                                       <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                 <Border Background="Transparent" Padding="4">
                                                                      <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                                 </Border>
                                                            </ControlTemplate>
                                                       </Button.Template>
                                                  </Button>
                                             </Grid>
                                        </Border>
                                   </DataTemplate>
                              </ItemsControl.ItemTemplate>
                         </ItemsControl>

                         <Button Content="💾  Save Scene"
                            Command="{Binding SaveSceneCommand}"
                            HorizontalAlignment="Left"
                            Padding="25,12" FontSize="14"/>
                    </StackPanel>
               </Border>

          </StackPanel>
     </ScrollViewer>
</UserControl>
