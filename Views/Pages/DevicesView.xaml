<UserControl x:Class="SmartHouseApp.Views.Pages.DevicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Grid Background="#0F172A">
        <StackPanel Margin="20">
            
            <TextBlock Text="Devices" FontSize="28" Foreground="White" Margin="0,0,0,20"/>
            
            <!-- Toolbar -->
            <StackPanel Orientation="Horizontal" Margin="0,10">
                <Button Content="Refresh" 
                        Command="{Binding RefreshCommand}"
                        Padding="15,8"
                        Margin="0,0,10,0"
                        Background="#3B82F6"
                        Foreground="White"
                        BorderThickness="0"/>
                <Button Content="Toggle All" 
                        Command="{Binding ToggleAllCommand}"
                        Padding="15,8"
                        Background="#6366F1"
                        Foreground="White"
                        BorderThickness="0"/>
            </StackPanel>
            
            <!-- Device List with proper binding -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Height="300">
                <ItemsControl ItemsSource="{Binding AllDevices}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1E293B" Padding="15" Margin="0,5" 
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Device Info -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" 
                                                   Foreground="White" 
                                                   FontSize="16"
                                                   FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Room}" 
                                                   Foreground="#94A3B8" 
                                                   FontSize="12"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                    
                                    <!-- Status and Toggle -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Status}" 
                                                   Foreground="#10B981" 
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,20,0"
                                                   VerticalAlignment="Center"/>
                                        <Button Content="Toggle" 
                                                Command="{Binding ToggleCommand}"
                                                Padding="15,6"
                                                Background="#10B981"
                                                Foreground="White"
                                                BorderThickness="0">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="4"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
        </StackPanel>
    </Grid>
</UserControl>
